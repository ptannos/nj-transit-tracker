{
  "name": "nj-transit-tracker",
  "version": "1.0.0",
  "description": "A portfolio app for tracking NJ transit buses and trains built with Lit",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src/**/*.ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "lit": "^3.1.2"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vitest": "^4.1.10"
  }
}
